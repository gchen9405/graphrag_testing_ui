{
  "name": "graphrag-test-ui",
  "version": "1.0.0",
  "private": true,
  "description": "Local testing UI for a Microsoft GraphRAG pipeline (Node.js + TypeScript backend wrapping the Windows GraphRAG executables).",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "prestart": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "busboy": "^1.6.0",
    "express": "^4.19.2",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/busboy": "^1.5.4",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18"
  }
}
